<%- include('partials/header') %>

<div class="dash-head">
  <h1>Admin Dashboard</h1>
  <a class="btn" href="/dashboard/new">+ New Post</a>
</div>

<table class="post-table">
  <thead>
    <tr><th>Title</th><th>Status</th><th>Author</th><th>Actions</th></tr>
  </thead>
  <tbody>
    <% posts.forEach(post => { %>
      <tr>
        <td><a href="/post/<%= post.slug %>"><%= post.title %></a></td>
        <td><%= post.published ? 'Published' : 'Draft' %></td>
        <td><%= post.author.name %></td>
        <td class="actions">
          <a href="/dashboard/edit/<%= post._id %>">Edit</a>
          <form action="/dashboard/delete/<%= post._id %>" method="POST" onsubmit="return confirm('Delete this post?');">
            <button type="submit" class="link-btn">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('partials/footer') %>