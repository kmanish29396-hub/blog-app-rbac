<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | RBAC Blog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="navbar">
    <a href="/" class="brand">📝 RBAC Blog</a>
    <nav>
      <a href="/">Home</a>
      <% if (user) { %>
        <% if (user.role === 'admin') { %>
          <a href="/dashboard">Dashboard</a>
        <% } %>
        <span class="who">Hi, <%= user.name %> (<%= user.role %>)</span>
        <a href="/auth/logout">Logout</a>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Register</a>
      <% } %>
    </nav>
  </header>

  <main class="container">
    <% if (typeof messages !== 'undefined' && messages.success && messages.success.length) { %>
      <div class="flash success"><%= messages.success[0] %></div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages.error && messages.error.length) { %>
      <div class="flash error"><%= messages.error[0] %></div>
    <% } %>